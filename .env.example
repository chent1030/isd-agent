FACE_API_URL=https://dify.uabcbattery.com:5000/face/Face0
STT_API_URL=http://10.133.190.16:3030/v1/audio/transcriptions
STT_MODEL=Fun-ASR-Nano-2512
STT_FILE_FIELD=file
STT_API_KEY=
TTS_API_URL=https://dify.uabcbattery.com:5000/tts/Voice2
LLM_API_URL=http://10.133.190.16:3030/v1
LLM_API_KEY=your-key-here
LLM_MODEL=gpt-4o-mini

# Dify Chat API
DIFY_API_URL=https://dify.uabcbattery.com:5000/api
DIFY_API_KEY=your-dify-key-here

# Set to true to bypass face recognition and enter guest mode.
SKIP_FACE_AUTH=false
SKIP_FACE_AUTH_EMP_NAME=
SKIP_FACE_AUTH_EMP_WORK_NO=

# Terminal returns to the home category page after this many idle minutes outside home.
TERMINAL_IDLE_TIMEOUT_MINUTES=5

ALLOW_INSECURE_TLS=true

# 3D rendering backend. Use swiftshader on machines where GPU/WebGL renders black.
# Options: auto, swiftshader, swiftshader-webgl, d3d11, d3d9, gl, vulkan
ISD_GRAPHICS_MODE=auto
ISD_IGNORE_GPU_BLOCKLIST=false

# Cabinet data and lock control
CABINET_LEDGER_API_BASE_URL=https://cshzeroapi.uabcbattery.com/unify/v1/1
CABINET_TWIN_LEFT_CABINET_NO=1
CABINET_TWIN_RIGHT_CABINET_NO=2
CABINET_LOCK_SERVER_IP=10.134.231.111
CABINET_LOCK_SERVER_PORT=10123
# Cabinet stock deduction timing. Options: door-close, door-open
CABINET_STOCK_DEDUCTION_MODE=door-close
